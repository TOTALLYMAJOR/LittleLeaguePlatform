# Local/Docker app port
APP_PORT=8081

# Future production placeholders only. Do not put real secrets in this file.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_DEFAULT_PROGRAM_THEME=baseball

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://dkwghvvlbdnnwzbnscvu.supabase.co
# Must be the public anon JWT. Never put the service_role JWT in a NEXT_PUBLIC_* key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only service role key. Never expose this through NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.dkwghvvlbdnnwzbnscvu.supabase.co:5432/postgres
DIRECT_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.dkwghvvlbdnnwzbnscvu.supabase.co:5432/postgres
SUPABASE_POOLER_DATABASE_URL=

# QA proof users; create/update with `npm run supabase:qa-users`.
QA_PARENT_EMAIL=
QA_PARENT_PASSWORD=
QA_COACH_EMAIL=
QA_COACH_PASSWORD=

# Maps, weather, notifications, and providers
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
TOMORROW_API_KEY=
WEATHER_PROVIDER_API_KEY=
AI_COACH_PROVIDER_ENABLED=false
OPENAI_API_KEY=
OPENAI_AI_COACH_MODEL=gpt-5.5
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
EMAIL_PROVIDER_API_KEY=
SMS_PROVIDER_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
